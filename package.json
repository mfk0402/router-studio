{
  "name": "router-studio",
  "version": "1.0.0",
  "description": "One workspace for every AI model",
  "main": "out/main/main.js",
  "author": "Router Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mfk0402/router-studio.git"
  },
  "bugs": {
    "url": "https://github.com/mfk0402/router-studio/issues"
  },
  "homepage": "https://github.com/mfk0402/router-studio#readme",
  "type": "module",
  "bin": {
    "router-studio": "bin/router-studio.mjs",
    "router": "bin/router-studio.mjs"
  },
  "files": [
    "bin/**/*",
    "out/**/*",
    "resources/**/*",
    "LICENSE",
    "scripts/ensure-native-toolchain.mjs"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.21.5",
    "@esbuild/darwin-x64": "0.21.5",
    "@esbuild/linux-arm64": "0.21.5",
    "@esbuild/linux-x64": "0.21.5",
    "@esbuild/win32-arm64": "0.21.5",
    "@esbuild/win32-ia32": "0.21.5",
    "@esbuild/win32-x64": "0.21.5",
    "@rollup/rollup-darwin-arm64": "4.60.2",
    "@rollup/rollup-darwin-x64": "4.60.2",
    "@rollup/rollup-linux-arm64-gnu": "4.60.2",
    "@rollup/rollup-linux-x64-gnu": "4.60.2",
    "@rollup/rollup-win32-arm64-msvc": "4.60.2",
    "@rollup/rollup-win32-ia32-msvc": "4.60.2",
    "@rollup/rollup-win32-x64-msvc": "4.60.2"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "verify": "npm run typecheck && electron-vite build",
    "build": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "assets:transparent-logos": "node scripts/make-logo-transparent.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:unit": "node --experimental-strip-types --test src/main/security/pathValidation.test.ts src/main/security/promptInjectionGuard.test.ts src/main/security/sensitiveFileGuard.test.ts src/main/tools/shell/runShell.test.ts src/renderer/lib/agentLoop.test.ts src/renderer/lib/fileUtils.test.ts src/renderer/lib/toolPromptGuide.test.ts",
    "test": "npm run test:unit && npm run verify",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "verify-server": "node server/email-verify/server.mjs",
    "postinstall": "node scripts/ensure-native-toolchain.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "diff": "^5.2.0",
    "electron-updater": "^6.6.2",
    "monaco-editor": "^0.50.0",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "typescript": "^5.5.3",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.router.studio",
    "productName": "Router Studio",
    "icon": "resources/icon.png",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "license": "LICENSE"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "resources/icon.png",
      "sign": null,
      "signDlls": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
